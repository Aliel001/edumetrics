{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/index.ts": {
      "includeFiles": ["prisma/**", "server.js"]
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
